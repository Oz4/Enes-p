---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Showreel from '../components/Showreel.astro';
import ProjectRail from '../components/ProjectRail.astro';
import ProjectSheet from '../components/ProjectSheet.astro';
import SkillsMap from '../components/SkillsMap.astro';
import QuestLog from '../components/QuestLog.astro';
import Achievements from '../components/Achievements.astro';
import Contact from '../components/Contact.astro';
import SceneCanvas from '../components/SceneCanvas.astro';
---

<Base
  title="Enes Sahin — Senior Unity Engineer"
  description="Senior Unity Engineer — systems, multiplayer, VR. From a 400K-player game built at university to a solo-shipped open-world simulator on Steam."
>
  <SceneCanvas />
  <Nav />
  <main id="main">
    <Hero />
    <Showreel />
    <ProjectRail />
    <SkillsMap />
    <QuestLog />
    <Achievements />
    <Contact />
  </main>
  <footer>
    <div class="container">
      <p>© 2026 Enes Sahin · Ankara, TR</p>
      <p class="net-line" id="net-line" aria-hidden="true">— delivery network offline —</p>
    </div>
  </footer>
  <ProjectSheet />
</Base>

<script>
  import '../scripts/reveal';
</script>

<style>
  footer {
    border-top: 1px solid var(--edge);
    padding-block: var(--space-4) var(--space-5);
  }

  footer .container {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    justify-content: space-between;
  }

  footer p {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    margin: 0;
  }

  .net-line {
    color: var(--neon-cyan);
    opacity: 0.7;
  }
</style>
