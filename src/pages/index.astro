---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Showreel from '../components/Showreel.astro';
import Projects from '../components/Projects.astro';
import SkillsMap from '../components/SkillsMap.astro';
import QuestLog from '../components/QuestLog.astro';
import Achievements from '../components/Achievements.astro';
import Contact from '../components/Contact.astro';
import SimCanvas from '../components/SimCanvas.astro';
import ProfilerBar from '../components/ProfilerBar.astro';
---

<Base
  title="Enes Sahin — Senior Unity Engineer"
  description="Senior Unity Engineer — systems, multiplayer, VR. From a 400K-player game built at university to a solo-shipped open-world simulator on Steam."
>
  <SimCanvas />
  <Nav />
  <main id="main">
    <Hero />
    <Showreel />
    <Projects />
    <SkillsMap />
    <QuestLog />
    <Achievements />
    <Contact />
  </main>
  <footer>
    <div class="container">
      <p>© 2026 Enes Sahin · Ankara, TR</p>
    </div>
  </footer>
  <ProfilerBar />
</Base>

<script>
  import '../scripts/reveal';
</script>

<style>
  footer {
    border-top: 1px solid var(--chunk-line);
    /* keep clear of the fixed profiler bar */
    padding-block: var(--space-4) var(--space-6);
  }

  footer p {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    margin: 0;
  }
</style>
