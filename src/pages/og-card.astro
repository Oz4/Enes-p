---
// 1200x630 source frame for public/og-image.png — screenshot with headless
// Chrome at that viewport. Not linked from anywhere; noindex.
import '@fontsource-variable/archivo/wdth.css';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>OG card</title>
  </head>
  <body>
    <div class="card">
      <p class="role">SENIOR UNITY ENGINEER — SYSTEMS · MULTIPLAYER · VR</p>
      <h1>Enes Sahin</h1>
      <p class="chips">Shipped on Steam · 400K+ players served · VR multiplayer · 10+ yrs</p>
      <p class="bar">network online · trails 22 · deliveries en route</p>
    </div>
  </body>
</html>

<style>
  body {
    margin: 0;
  }

  .card {
    background:
      radial-gradient(ellipse 55% 45% at 22% 28%, rgba(139, 92, 246, 0.16), transparent 70%),
      radial-gradient(ellipse 50% 42% at 78% 62%, rgba(34, 211, 238, 0.12), transparent 70%),
      radial-gradient(ellipse 42% 32% at 55% 95%, rgba(255, 180, 84, 0.1), transparent 70%),
      var(--void);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    height: 630px;
    justify-content: center;
    padding: 0 80px;
    position: relative;
    width: 1200px;
  }

  .role {
    color: var(--trail-amber);
    font-family: var(--font-mono);
    font-size: 24px;
    letter-spacing: 0.05em;
    margin: 0 0 24px;
    text-shadow: 0 0 22px rgba(255, 180, 84, 0.5);
  }

  h1 {
    background: linear-gradient(100deg, var(--ink), var(--neon-violet) 35%, var(--neon-cyan) 70%, var(--ink));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    font-family: 'Archivo Variable', sans-serif;
    font-stretch: expanded;
    font-size: 120px;
    font-weight: 900;
    line-height: 1;
    margin: 0 0 32px;
  }

  .chips {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 26px;
    margin: 0;
  }

  .bar {
    border-top: 1px solid var(--edge);
    bottom: 0;
    color: var(--neon-cyan);
    font-family: var(--font-mono);
    font-size: 20px;
    left: 0;
    margin: 0;
    padding: 18px 80px;
    position: absolute;
    right: 0;
    text-shadow: 0 0 18px rgba(34, 211, 238, 0.6);
  }
</style>
