---
interface Props {
  tech: {
    engine: string;
    language: string;
    networking: string;
    keyLibs: string;
    platform: string;
    teamSize: string;
    role: string;
  };
}

const { tech } = Astro.props;

const rows: [string, string][] = [
  ['engine', tech.engine],
  ['language', tech.language],
  ['networking', tech.networking],
  ['key libs', tech.keyLibs],
  ['platform', tech.platform],
  ['team size', tech.teamSize],
  ['role', tech.role],
];
---

<aside class="tech-box" aria-label="Technical summary">
  <h2>Tech box</h2>
  <dl>
    {
      rows.map(([label, value]) => (
        <div class="row">
          <dt>{label}</dt>
          <dd>{value}</dd>
        </div>
      ))
    }
  </dl>
</aside>

<style>
  .tech-box {
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      var(--grad-edge) border-box;
    border: 1px solid transparent;
    border-radius: var(--radius);
    padding: var(--space-4);
  }

  h2 {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-stretch: normal;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
    text-transform: uppercase;
  }

  dl {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin: 0;
  }

  .row {
    display: grid;
    gap: var(--space-2);
    grid-template-columns: 7rem 1fr;
  }

  dt {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  dd {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    margin: 0;
  }
</style>
