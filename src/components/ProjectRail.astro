---
// PS5-style horizontal project rail. Cards open the bottom-sheet case study
// (ProjectSheet). Art + trailers are PLACEHOLDERS: AAA-game YouTube material
// stands in until Enes's real capture exists.
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const thumb = (id: string | undefined) =>
  id ? `https://i.ytimg.com/vi/${id}/maxresdefault.jpg` : '/media/showreel-poster.svg';
---

<section class="section" id="projects">
  <div class="container reveal">
    <h2 class="section-title"><span class="index">01 /</span> Featured projects</h2>
    <p class="lede rail-hint">drag · scroll · arrow keys — click a card for the case study</p>
  </div>
  <div class="rail" id="project-rail" aria-label="Featured projects — horizontal list">
    {
      projects.map((p, i) => (
        <button
          class="rail-card"
          data-slug={p.id}
          data-yt={p.data.trailer}
          aria-haspopup="dialog"
          aria-label={`${p.data.title} — open case study`}
        >
          <img
            src={thumb(p.data.trailer)}
            alt=""
            width="960"
            height="720"
            loading={i < 2 ? 'eager' : 'lazy'}
          />
          <span class="video-slot" aria-hidden="true"></span>
          <span class="scrim" aria-hidden="true"></span>
          <span class="info">
            <span class="title">{p.data.title}</span>
            <span class="role">{p.data.roleLine}</span>
            <span class="chips">
              {p.data.chips.map((c) => (
                <span class="mini-chip">{c}</span>
              ))}
            </span>
          </span>
        </button>
      ))
    }
  </div>
</section>

<script>
  const rail = document.getElementById('project-rail');
  if (rail) {
    const cards = [...rail.querySelectorAll<HTMLButtonElement>('.rail-card')];
    let interacted = false;
    let dragging = false;

    // --- active card = nearest to rail center; mounts its trailer ---
    let activeCard: HTMLButtonElement | null = null;

    function mountVideo(card: HTMLButtonElement): void {
      const slot = card.querySelector('.video-slot');
      const yt = card.dataset.yt;
      if (!slot || !yt || slot.firstChild || !interacted) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${yt}?autoplay=1&mute=1&controls=0&loop=1&playlist=${yt}&playsinline=1&rel=0`;
      iframe.allow = 'autoplay; encrypted-media';
      iframe.tabIndex = -1;
      iframe.title = '';
      iframe.setAttribute('aria-hidden', 'true');
      slot.appendChild(iframe);
    }

    function setActive(): void {
      const mid = rail!.getBoundingClientRect().left + rail!.clientWidth / 2;
      let best: HTMLButtonElement | null = null;
      let bestDist = Infinity;
      for (const card of cards) {
        const r = card.getBoundingClientRect();
        const d = Math.abs(r.left + r.width / 2 - mid);
        if (d < bestDist) {
          bestDist = d;
          best = card;
        }
      }
      if (best === activeCard) return;
      activeCard?.classList.remove('active');
      activeCard?.querySelector('.video-slot')?.replaceChildren();
      activeCard = best;
      if (activeCard) {
        activeCard.classList.add('active');
        mountVideo(activeCard);
      }
    }

    let scrollRaf = 0;
    rail.addEventListener(
      'scroll',
      () => {
        cancelAnimationFrame(scrollRaf);
        scrollRaf = requestAnimationFrame(setActive);
      },
      { passive: true },
    );
    setActive();

    const markInteracted = () => {
      if (interacted) return;
      interacted = true;
      if (activeCard) mountVideo(activeCard);
    };
    for (const evt of ['pointerdown', 'wheel', 'keydown', 'touchstart']) {
      rail.addEventListener(evt, markInteracted, { passive: true, once: false });
    }

    // --- vertical wheel drives the rail while hovering it ---
    rail.addEventListener(
      'wheel',
      (e) => {
        if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
          const atStart = rail!.scrollLeft <= 0 && e.deltaY < 0;
          const atEnd =
            rail!.scrollLeft >= rail!.scrollWidth - rail!.clientWidth - 1 && e.deltaY > 0;
          if (!atStart && !atEnd) {
            e.preventDefault();
            rail!.scrollLeft += e.deltaY;
          }
        }
      },
      { passive: false },
    );

    // --- mouse drag (touch scrolls natively) ---
    let dragStartX = 0;
    let dragStartScroll = 0;
    rail.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse') return;
      dragging = false;
      dragStartX = e.clientX;
      dragStartScroll = rail!.scrollLeft;
      const move = (ev: PointerEvent) => {
        const dx = ev.clientX - dragStartX;
        if (Math.abs(dx) > 6) {
          dragging = true;
          rail!.style.scrollSnapType = 'none';
          rail!.scrollLeft = dragStartScroll - dx;
        }
      };
      const up = () => {
        window.removeEventListener('pointermove', move);
        window.removeEventListener('pointerup', up);
        if (dragging) {
          // snap back to the nearest card; let the trailing click be
          // suppressed first, then clear the flag
          rail!.style.scrollSnapType = '';
          activeCard?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
          setTimeout(() => {
            dragging = false;
          }, 0);
        }
      };
      window.addEventListener('pointermove', move);
      window.addEventListener('pointerup', up);
    });

    // suppress the click that ends a drag
    rail.addEventListener(
      'click',
      (e) => {
        if (dragging) {
          e.stopPropagation();
          e.preventDefault();
        }
      },
      { capture: true },
    );

    // --- arrow keys ---
    rail.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
      e.preventDefault();
      const idx = activeCard ? cards.indexOf(activeCard) : 0;
      const next = cards[Math.min(cards.length - 1, Math.max(0, idx + (e.key === 'ArrowRight' ? 1 : -1)))];
      next?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      next?.focus({ preventScroll: true });
    });
  }
</script>

<style>
  .rail-hint {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .rail {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-4);
    overflow-x: auto;
    overscroll-behavior-x: contain;
    padding-block: var(--space-4) var(--space-5);
    padding-inline: max(calc((100vw - 23rem) / 2), var(--space-4));
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .rail::-webkit-scrollbar {
    display: none;
  }

  .rail-card {
    aspect-ratio: 3 / 4;
    background: var(--surface);
    border: 1px solid transparent;
    border-radius: var(--radius);
    cursor: pointer;
    flex: 0 0 auto;
    filter: brightness(0.6) saturate(0.85);
    overflow: hidden;
    padding: 0;
    position: relative;
    scroll-snap-align: center;
    transform: scale(0.97);
    transition:
      transform 0.3s ease-out,
      filter 0.3s ease-out,
      box-shadow 0.3s ease-out;
    width: min(72vw, 23rem);
  }

  .rail-card.active {
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      var(--grad-edge) border-box;
    box-shadow:
      0 12px 50px rgba(0, 0, 0, 0.55),
      0 0 44px rgba(139, 92, 246, 0.14);
    filter: none;
    transform: scale(1.05);
    z-index: 1;
  }

  .rail-card img,
  .video-slot :global(iframe) {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
  }

  /* 16:9 trailer covering a 3:4 card */
  .video-slot :global(iframe) {
    border: 0;
    height: 100%;
    left: 50%;
    pointer-events: none;
    transform: translateX(-50%);
    width: 178%;
  }

  .scrim {
    background: linear-gradient(180deg, transparent 40%, rgba(6, 6, 8, 0.55) 68%, rgba(6, 6, 8, 0.92));
    inset: 0;
    position: absolute;
  }

  .info {
    bottom: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    left: 0;
    padding: var(--space-4);
    position: absolute;
    right: 0;
    text-align: left;
  }

  .title {
    color: var(--ink);
    font-family: var(--font-display);
    font-stretch: expanded;
    font-size: var(--text-md);
    font-weight: 800;
    line-height: 1.2;
  }

  .role {
    color: var(--trail-amber);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin-top: var(--space-1);
  }

  .mini-chip {
    background: rgba(6, 6, 8, 0.55);
    border: 1px solid var(--edge);
    border-radius: 999px;
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 1px var(--space-2);
  }
</style>
