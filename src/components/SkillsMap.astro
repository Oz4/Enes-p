---
// "Systems map" — six angular color plates, the one deliberately loud
// moment on the page. Four colors only (vibrant purple, orange, yellow,
// darker blue), assigned so no two neighbors share a color. Every plate is
// a 5- or 6-sided polygon built from ONE shared slope system (vertical
// edges lean −3% top→bottom, horizontal edges +2% left→right, one chamfer
// family) so adjacent plates' facing edges are parallel — organized, not
// noisy. Plate colors come from --plate-* tokens and appear nowhere else.
const branches = [
  {
    name: 'Unity & Engine',
    fill: 'var(--plate-orange)',
    text: 'var(--plate-ink)',
    pose: '--dy:-16px; --ry:-3deg; --dx:-10px',
    clip: 'polygon(3% 0%, 86% 1.7%, 99.5% 18%, 97% 100%, 14% 98.3%, 0.4% 84%)',
    clipM: 'polygon(1.5% 0%, 92% 0.9%, 99.8% 9%, 98.5% 100%, 7% 99.2%, 0.2% 92%)',
    nodes: [
      { label: 'GameObject architecture' },
      { label: 'DOTS / ECS' },
      { label: 'Jobs + Burst' },
      { label: 'Addressables', proof: 'Cargo Simulator chunk streaming' },
      { label: 'Profiling' },
    ],
  },
  {
    name: 'Architecture',
    fill: 'var(--plate-purple)',
    text: 'var(--ink)',
    pose: '--dy:26px; --ry:2deg; --dx:10px',
    clip: 'polygon(17% 0.3%, 100% 2%, 97.5% 84%, 84% 99.7%, 0% 98%, 2.5% 16%)',
    clipM: 'polygon(8.5% 0.2%, 100% 1%, 98.8% 92%, 92% 99.9%, 0% 99%, 1.2% 8%)',
    nodes: [
      { label: 'Composition over inheritance' },
      { label: 'DI — Zenject / VContainer' },
      { label: 'SOLID' },
      { label: 'Modular assemblies', proof: 'HG framework, 10+ titles' },
    ],
  },
  {
    name: 'Multiplayer',
    fill: 'var(--plate-blue)',
    text: 'var(--ink)',
    pose: '--dy:-34px; --ry:-2deg; --dx:-8px',
    clip: 'polygon(3% 0%, 84% 1.6%, 99.6% 16%, 97.5% 86%, 86% 99.8%, 0% 98%)',
    clipM: 'polygon(1.5% 0%, 92% 0.8%, 99.8% 8%, 98.8% 93%, 93% 99.9%, 0% 99%)',
    nodes: [
      { label: 'Client-server model' },
      { label: 'Replication', proof: 'Highstreet VR multiplayer' },
      { label: 'Prediction' },
      { label: 'Packing & compression' },
    ],
  },
  {
    name: 'VR & Physics',
    fill: 'var(--plate-purple)',
    text: 'var(--ink)',
    pose: '--dy:20px; --ry:3deg; --dx:12px',
    clip: 'polygon(16% 0.3%, 100% 2%, 97% 100%, 15% 98.3%, 0.5% 86%, 2.6% 14%)',
    clipM: 'polygon(8% 0.2%, 100% 1%, 98.5% 100%, 7.5% 99.2%, 0.2% 93%, 1.3% 7%)',
    nodes: [
      { label: 'IK' },
      { label: 'Joints & constraints', proof: 'Highstreet VR combat' },
      { label: 'Interaction systems' },
    ],
  },
  {
    name: 'AI & Procedural',
    fill: 'var(--plate-yellow)',
    text: 'var(--plate-ink)',
    pose: '--dy:38px; --ry:-3deg; --dx:-12px',
    clip: 'polygon(3% 0%, 84% 1.6%, 99.5% 17%, 97% 100%, 0% 98%)',
    clipM: 'polygon(1.5% 0%, 92% 0.8%, 99.8% 8.5%, 98.5% 100%, 0% 99%)',
    nodes: [
      { label: 'FSM', proof: 'Cargo Simulator delivery agents' },
      { label: 'Behavior trees' },
      { label: 'NavMesh' },
      { label: 'Procedural roads', proof: 'Cargo Simulator' },
    ],
  },
  {
    name: 'Backend & Tools',
    fill: 'var(--plate-orange)',
    text: 'var(--plate-ink)',
    pose: '--dy:-22px; --ry:2deg; --dx:8px',
    clip: 'polygon(3% 0%, 100% 2%, 97% 100%, 15% 98.3%, 0.4% 83%)',
    clipM: 'polygon(1.5% 0%, 100% 1%, 98.5% 100%, 7.5% 99.2%, 0.2% 91.5%)',
    nodes: [
      { label: 'ASP.NET' },
      { label: 'MySQL / NoSQL' },
      { label: 'Firebase' },
      { label: 'CI/CD', proof: 'HG Builder — 2+ hrs/day saved' },
      { label: 'Python' },
    ],
  },
];
---

<section class="section" id="skills">
  <div class="container reveal">
    <h2 class="section-title"><span class="index">02 /</span> Systems map</h2>
    <p class="lede">
      No levels, no percentages. Where it matters, a node points at the shipped work that
      proves it.
    </p>
    <div class="stage">
      {
        branches.map((branch) => (
          <article
            class="plate"
            style={`${branch.pose}; --fill:${branch.fill}; --text:${branch.text}; --clip:${branch.clip}; --clip-m:${branch.clipM}`}
          >
            <h3>{branch.name}</h3>
            <ul>
              {branch.nodes.map((node) => (
                <li>
                  <span class="node">{node.label}</span>
                  {node.proof && <span class="proof">used in: {node.proof}</span>}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .lede {
    margin-bottom: var(--space-5);
  }

  .stage {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
    perspective: 1400px;
  }

  @media (min-width: 768px) {
    .stage {
      gap: var(--space-4) var(--space-3);
      grid-template-columns: 1fr 1fr 1fr;
      padding-block: var(--space-5);
    }
  }

  /* Angular color plate: solid saturated fill, 5-6 sided sharp polygon.
     No borders, no glow — the color is the whole event. */
  .plate {
    background: var(--fill);
    clip-path: var(--clip);
    padding: var(--space-4) var(--space-4) var(--space-5);
    transition:
      transform 0.25s ease-out,
      filter 0.25s ease-out;
  }

  @media (min-width: 768px) {
    .plate {
      transform: translateY(var(--dy)) rotateY(var(--ry));
    }

    .plate:hover,
    .plate:focus-within {
      filter: brightness(1.06);
      transform: translateY(calc(var(--dy) - 5px)) rotateY(var(--ry));
    }
  }

  /* Mobile: stacked, shallower cuts, small alternating x-offsets */
  @media (max-width: 767px) {
    .plate {
      clip-path: var(--clip-m);
      transform: translateX(var(--dx));
    }

    .plate:hover {
      filter: brightness(1.06);
      transform: translateX(var(--dx)) translateY(-5px);
    }
  }

  h3,
  .node {
    color: var(--text);
  }

  h3 {
    border-bottom: 1px solid color-mix(in srgb, var(--text) 30%, transparent);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: flex;
    flex-direction: column;
  }

  .node {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .node::before {
    content: '▪ ';
  }

  .proof {
    color: color-mix(in srgb, var(--text) 72%, transparent);
    font-size: var(--text-xs);
    padding-left: var(--space-3);
  }
</style>
