---
// "Systems map" — a seamed mosaic: ONE master panel sliced into six plates
// by shared seam lines, so adjacent edges are exactly parallel (honeycomb
// logic) and no edge in the section is axis-aligned, no corner 90°.
// All geometry derives from the SEAM constants below at build time.

type Pt = { x: number; y: number };
type Line = { p: Pt; d: Pt };

// ---------------------------------------------------------------------
// SEAM GEOMETRY — the whole composition tunes from these numbers.
// Reference panel: 976 × 470 px (the content column at 1280 viewport).
// ---------------------------------------------------------------------
const W = 976;
const H = 520;
const SEAM = {
  v1x: 310, //  first "vertical" seam: x at the panel top
  v1TiltDeg: 6, //  … tilted from vertical
  v2x: 664, //  second vertical seam
  v2TiltDeg: -7, //  … tilted the opposite way
  hy: 240, //  "horizontal" seam: y at the panel left
  hTiltDeg: 2.5, //  … tilted from horizontal
  outerTiltDeg: 1.7, //  boundary edges — nothing axis-aligned
  insetPx: 8, //  plate inset toward its centroid (half-gutter)
  safePx: 28, //  minimum text distance from any angled edge
};

const rad = (d: number) => (d * Math.PI) / 180;
const line = (a: Pt, b: Pt): Line => ({ p: a, d: { x: b.x - a.x, y: b.y - a.y } });
const intersect = (l1: Line, l2: Line): Pt => {
  const den = l1.d.x * l2.d.y - l1.d.y * l2.d.x;
  const t = ((l2.p.x - l1.p.x) * l2.d.y - (l2.p.y - l1.p.y) * l2.d.x) / den;
  return { x: l1.p.x + l1.d.x * t, y: l1.p.y + l1.d.y * t };
};

// seams
const v1 = line({ x: SEAM.v1x, y: 0 }, { x: SEAM.v1x + Math.tan(rad(SEAM.v1TiltDeg)) * H, y: H });
const v2 = line({ x: SEAM.v2x, y: 0 }, { x: SEAM.v2x + Math.tan(rad(SEAM.v2TiltDeg)) * H, y: H });
const hSeam = line({ x: 0, y: SEAM.hy }, { x: W, y: SEAM.hy + Math.tan(rad(SEAM.hTiltDeg)) * W });
// outer boundary (tilted, so no 90° corners anywhere)
const dOut = Math.tan(rad(SEAM.outerTiltDeg));
const top = line({ x: 0, y: dOut * W }, { x: W, y: 0 });
const bottom = line({ x: 0, y: H }, { x: W, y: H - dOut * W });
const left = line({ x: dOut * H, y: 0 }, { x: 0, y: H });
const right = line({ x: W, y: 0 }, { x: W - dOut * H, y: H });

// six cells, each an ordered edge loop (edges shared with neighbors)
const cellEdges: Line[][] = [
  [top, v1, hSeam, left],
  [top, v2, hSeam, v1],
  [top, right, hSeam, v2],
  [hSeam, v1, bottom, left],
  [hSeam, v2, bottom, v1],
  [hSeam, right, bottom, v2],
];

const polyFromLines = (ls: Line[]): Pt[] => ls.map((l, i) => intersect(l, ls[(i + 1) % ls.length] as Line));

/** Shift every edge toward the cell centroid by d, re-intersect. */
const insetPoly = (ls: Line[], d: number): Pt[] => {
  const poly = polyFromLines(ls);
  const c = poly.reduce((a, p) => ({ x: a.x + p.x / poly.length, y: a.y + p.y / poly.length }), { x: 0, y: 0 });
  const shifted = ls.map((l) => {
    const len = Math.hypot(l.d.x, l.d.y);
    let n = { x: -l.d.y / len, y: l.d.x / len };
    if (n.x * (c.x - l.p.x) + n.y * (c.y - l.p.y) < 0) n = { x: -n.x, y: -n.y };
    return { p: { x: l.p.x + n.x * d, y: l.p.y + n.y * d }, d: l.d };
  });
  return polyFromLines(shifted);
};

interface PlateGeo {
  leftPct: string;
  topPct: string;
  widthPct: string;
  heightPct: string;
  clip: string;
  padding: string;
}

const geo: PlateGeo[] = cellEdges.map((ls) => {
  const pts = insetPoly(ls, SEAM.insetPx);
  const xs = pts.map((p) => p.x);
  const ys = pts.map((p) => p.y);
  const minX = Math.min(...xs);
  const maxX = Math.max(...xs);
  const minY = Math.min(...ys);
  const maxY = Math.max(...ys);
  const bw = maxX - minX;
  const bh = maxY - minY;
  const clip = pts
    .map((p) => `${(((p.x - minX) / bw) * 100).toFixed(2)}% ${(((p.y - minY) / bh) * 100).toFixed(2)}%`)
    .join(', ');
  // clip-aware padding: worst-case recession of each tilted edge + safety
  const sx = [...xs].sort((a, b) => a - b);
  const sy = [...ys].sort((a, b) => a - b);
  const padT = Math.round((sy[1] as number) - (sy[0] as number) + SEAM.safePx);
  const padB = Math.round((sy[3] as number) - (sy[2] as number) + SEAM.safePx);
  const padL = Math.round((sx[1] as number) - (sx[0] as number) + SEAM.safePx);
  const padR = Math.round((sx[3] as number) - (sx[2] as number) + SEAM.safePx);
  // paddings in container-query units so the whole system — plate, type,
  // and safety margins — scales as one (values are px at the 976 reference)
  const cq = (px: number) => `${((px / W) * 100).toFixed(3)}cqi`;
  return {
    leftPct: ((minX / W) * 100).toFixed(2),
    topPct: ((minY / H) * 100).toFixed(2),
    widthPct: ((bw / W) * 100).toFixed(2),
    heightPct: ((bh / H) * 100).toFixed(2),
    clip,
    padding: `${cq(padT)} ${cq(padR)} ${cq(padB)} ${cq(padL)}`,
  };
});

// Fills: all carry white text. Green and orange are darkened from the
// art-direction picks (#0E9F5B → 3.4:1, #EA580C → 3.6:1 vs white) to hold
// the ≥4.5:1 floor; the rest are as specified.
const branches = [
  {
    name: 'Unity & Engine',
    fill: 'var(--plate-orange)',
    text: 'var(--plate-ink)',
    compact: true,
    nodes: [
      { label: 'GameObject architecture' },
      { label: 'DOTS / ECS' },
      { label: 'Jobs + Burst' },
      { label: 'Addressables', proof: 'Cargo Simulator chunk streaming' },
      { label: 'Profiling' },
    ],
  },
  {
    name: 'Architecture',
    fill: 'var(--plate-violet)',
    text: 'rgba(255, 255, 255, 1)',
    compact: true,
    nodes: [
      { label: 'Composition over inheritance' },
      { label: 'DI — Zenject / VContainer' },
      { label: 'SOLID' },
      { label: 'Modular assemblies', proof: 'HG framework, 10+ titles' },
    ],
  },
  {
    name: 'Multiplayer',
    fill: 'var(--plate-teal)',
    text: 'var(--plate-ink)',
    compact: false,
    nodes: [
      { label: 'Client-server model' },
      { label: 'Replication', proof: 'Highstreet VR multiplayer' },
      { label: 'Prediction' },
      { label: 'Packing & compression' },
    ],
  },
  {
    name: 'VR & Physics',
    fill: 'var(--plate-magenta)',
    text: 'rgba(255, 255, 255, 1)',
    compact: false,
    nodes: [
      { label: 'IK' },
      { label: 'Joints & constraints', proof: 'Highstreet VR combat' },
      { label: 'Interaction systems' },
    ],
  },
  {
    name: 'AI & Procedural',
    fill: 'var(--plate-green)',
    text: 'var(--plate-ink)',
    compact: true,
    nodes: [
      { label: 'FSM', proof: 'Cargo Simulator delivery agents' },
      { label: 'Behavior trees' },
      { label: 'NavMesh' },
      { label: 'Procedural roads', proof: 'Cargo Simulator' },
    ],
  },
  {
    name: 'Backend & Tools',
    fill: 'var(--plate-cobalt)',
    text: 'var(--plate-ink)', /* cobalt token is currently tuned to orange — flip to white if it goes back to blue */
    compact: true,
    nodes: [
      { label: 'ASP.NET' },
      { label: 'MySQL / NoSQL' },
      { label: 'Firebase' },
      { label: 'CI/CD', proof: 'HG Builder — 2+ hrs/day saved' },
      { label: 'Python' },
    ],
  },
];
---

<section class="section" id="skills">
  <div class="container reveal">
    <h2 class="section-title"><span class="index">02 /</span> Systems map</h2>
    <p class="lede">
      No levels, no percentages. Where it matters, a node points at the shipped work that
      proves it.
    </p>
    <div class="mosaic">
      {
        branches.map((branch, i) => {
          const g = geo[i] as PlateGeo;
          return (
            <article
              class:list={['plate', { compact: branch.compact }]}
              style={`--fill:${branch.fill}; --text:${branch.text}; --l:${g.leftPct}%; --t:${g.topPct}%; --w:${g.widthPct}%; --h:${g.heightPct}%; --clip:polygon(${g.clip}); --pad:${g.padding}`}
            >
              <h3>{branch.name}</h3>
              <ul>
                {branch.nodes.map((node) => (
                  <li>
                    <span class="node">{node.label}</span>
                    {node.proof && <span class="proof">used in: {node.proof}</span>}
                  </li>
                ))}
              </ul>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .lede {
    margin-bottom: var(--space-5);
  }

  /* --- desktop: the seamed mosaic --- */
  @media (min-width: 768px) {
    .mosaic {
      aspect-ratio: 976 / 520;
      container-type: inline-size;
      position: relative;
      width: 100%;
    }

    .plate {
      background: var(--fill);
      clip-path: var(--clip);
      height: var(--h);
      left: var(--l);
      padding: var(--pad);
      position: absolute;
      top: var(--t);
      transition:
        transform 0.25s ease-out,
        filter 0.25s ease-out;
      width: var(--w);
    }

    .plate:hover,
    .plate:focus-within {
      filter: brightness(1.05);
      transform: translateY(-4px);
    }
  }

  /* --- mobile: full-width parallelograms, alternating tilt --- */
  @media (max-width: 767px) {
    .mosaic {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .plate {
      background: var(--fill);
      clip-path: polygon(0 12px, 100% 0, 100% calc(100% - 12px), 0 100%);
      padding: 44px 28px;
    }

    .plate:nth-child(even) {
      clip-path: polygon(0 0, 100% 12px, 100% 100%, 0 calc(100% - 12px));
    }
  }

  h3 {
    border-bottom: 1px solid color-mix(in srgb, var(--text) 40%, transparent);
    color: var(--text);
    font-size: 0.875rem;
    margin-bottom: var(--space-2);
    padding-bottom: 6px;
  }


  ul {
    display: flex;
    flex-direction: column;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: flex;
    flex-direction: column;
  }

  .node {
    color: color-mix(in srgb, var(--text) 95%, transparent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.4;
  }

  .node::before {
    content: '▪ ';
  }

  .proof {
    color: color-mix(in srgb, var(--text) 78%, transparent);
    font-size: var(--text-xs);
    line-height: 1.35;
    padding-left: var(--space-3);
  }

  /* one step down for lists that would otherwise crowd their polygon
     (sizes live in the cqi block above) */
  @media (min-width: 768px) {
    .compact .node {
      line-height: 1.3;
    }

    .compact h3 {
      margin-bottom: var(--space-1);
    }
  }

  /* Inside the mosaic, type tracks the panel width (14px/12.8px/11px at
     the 976px reference) so plates never outgrow their polygons as the
     panel scales down between breakpoints. */
  @media (min-width: 768px) {
    h3 {
      font-size: 1.44cqi;
    }

    .node,
    .proof {
      font-size: 1.31cqi;
    }

    ul {
      gap: 0.41cqi;
    }

    .compact .node,
    .compact .proof {
      font-size: 1.13cqi;
    }

    .compact ul {
      gap: 0.31cqi;
    }
  }
</style>
