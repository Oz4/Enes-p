---
// "Systems map" — six angular color plates, the one deliberately loud
// moment on the page. Each category is an irregular clip-path polygon
// (edges 2-6° off-axis, every plate a different fixed shape, facing edges
// roughly parallel) with a solid saturated fill and near-black text.
// Plate colors come from the --plate-* tokens and appear NOWHERE else.
const branches = [
  {
    name: 'Unity & Engine',
    fill: 'var(--plate-orange)',
    pose: '--dy:-16px; --ry:-3deg; --dx:-10px',
    clip: 'polygon(0% 2%, 98% 0%, 100% 98%, 3% 100%)',
    clipM: 'polygon(0% 1%, 99% 0%, 100% 99%, 1.5% 100%)',
    nodes: [
      { label: 'GameObject architecture' },
      { label: 'DOTS / ECS' },
      { label: 'Jobs + Burst' },
      { label: 'Addressables', proof: 'Cargo Simulator chunk streaming' },
      { label: 'Profiling' },
    ],
  },
  {
    name: 'Architecture',
    fill: 'var(--plate-violet)',
    pose: '--dy:26px; --ry:2deg; --dx:10px',
    clip: 'polygon(2% 0%, 100% 3%, 97% 100%, 4% 98%)',
    clipM: 'polygon(1% 0%, 100% 1.5%, 98.5% 100%, 2% 99%)',
    nodes: [
      { label: 'Composition over inheritance' },
      { label: 'DI — Zenject / VContainer' },
      { label: 'SOLID' },
      { label: 'Modular assemblies', proof: 'HG framework, 10+ titles' },
    ],
  },
  {
    name: 'Multiplayer',
    fill: 'var(--plate-cyan)',
    pose: '--dy:-34px; --ry:-2deg; --dx:-8px',
    clip: 'polygon(3% 2%, 98% 0%, 100% 100%, 0% 97%)',
    clipM: 'polygon(1.5% 1%, 99% 0%, 100% 100%, 0% 98.5%)',
    nodes: [
      { label: 'Client-server model' },
      { label: 'Replication', proof: 'Highstreet VR multiplayer' },
      { label: 'Prediction' },
      { label: 'Packing & compression' },
    ],
  },
  {
    name: 'VR & Physics',
    fill: 'var(--plate-magenta)',
    pose: '--dy:20px; --ry:3deg; --dx:12px',
    clip: 'polygon(0% 0%, 97% 2%, 100% 97%, 2% 100%)',
    clipM: 'polygon(0% 0%, 98.5% 1%, 100% 98.5%, 1% 100%)',
    nodes: [
      { label: 'IK' },
      { label: 'Joints & constraints', proof: 'Highstreet VR combat' },
      { label: 'Interaction systems' },
    ],
  },
  {
    name: 'AI & Procedural',
    fill: 'var(--plate-acid)',
    pose: '--dy:38px; --ry:-3deg; --dx:-12px',
    clip: 'polygon(2% 3%, 98% 0%, 100% 96%, 60% 100%, 0% 98%)',
    clipM: 'polygon(1% 1.5%, 99% 0%, 100% 98%, 60% 100%, 0% 99%)',
    nodes: [
      { label: 'FSM', proof: 'Cargo Simulator delivery agents' },
      { label: 'Behavior trees' },
      { label: 'NavMesh' },
      { label: 'Procedural roads', proof: 'Cargo Simulator' },
    ],
  },
  {
    name: 'Backend & Tools',
    fill: 'var(--plate-yellow)',
    pose: '--dy:-22px; --ry:2deg; --dx:8px',
    clip: 'polygon(0% 2%, 100% 0%, 98% 98%, 3% 96%)',
    clipM: 'polygon(0% 1%, 100% 0%, 99% 99%, 1.5% 98%)',
    nodes: [
      { label: 'ASP.NET' },
      { label: 'MySQL / NoSQL' },
      { label: 'Firebase' },
      { label: 'CI/CD', proof: 'HG Builder — 2+ hrs/day saved' },
      { label: 'Python' },
    ],
  },
];
---

<section class="section" id="skills">
  <div class="container reveal">
    <h2 class="section-title"><span class="index">02 /</span> Systems map</h2>
    <p class="lede">
      No levels, no percentages. Where it matters, a node points at the shipped work that
      proves it.
    </p>
    <div class="stage">
      {
        branches.map((branch) => (
          <article
            class="plate"
            style={`${branch.pose}; --fill:${branch.fill}; --clip:${branch.clip}; --clip-m:${branch.clipM}`}
          >
            <h3>{branch.name}</h3>
            <ul>
              {branch.nodes.map((node) => (
                <li>
                  <span class="node">{node.label}</span>
                  {node.proof && <span class="proof">used in: {node.proof}</span>}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .lede {
    margin-bottom: var(--space-5);
  }

  .stage {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
    perspective: 1400px;
  }

  @media (min-width: 768px) {
    .stage {
      gap: var(--space-4) var(--space-3);
      grid-template-columns: 1fr 1fr 1fr;
      padding-block: var(--space-5);
    }
  }

  /* Angular color plate: solid saturated fill, irregular sharp polygon.
     No borders, no glow — the color is the whole event. */
  .plate {
    background: var(--fill);
    clip-path: var(--clip);
    padding: var(--space-4) var(--space-4) var(--space-5);
    transition:
      transform 0.25s ease-out,
      filter 0.25s ease-out;
  }

  @media (min-width: 768px) {
    .plate {
      transform: translateY(var(--dy)) rotateY(var(--ry));
    }

    .plate:hover,
    .plate:focus-within {
      filter: brightness(1.06);
      transform: translateY(calc(var(--dy) - 5px)) rotateY(var(--ry));
    }
  }

  /* Mobile: stacked, shallower cuts, small alternating x-offsets */
  @media (max-width: 767px) {
    .plate {
      clip-path: var(--clip-m);
      transform: translateX(var(--dx));
    }

    .plate:hover {
      filter: brightness(1.06);
      transform: translateX(var(--dx)) translateY(-5px);
    }
  }

  h3,
  .node {
    color: var(--plate-ink);
  }

  h3 {
    border-bottom: 1px solid color-mix(in srgb, var(--plate-ink) 30%, transparent);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: flex;
    flex-direction: column;
  }

  .node {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .node::before {
    content: '▪ ';
  }

  .proof {
    color: color-mix(in srgb, var(--plate-ink) 70%, transparent);
    font-size: var(--text-xs);
    padding-left: var(--space-3);
  }
</style>
