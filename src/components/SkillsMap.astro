---
// "Systems map" — six tall panels floating in the scene like act-selection
// cards. Tilts/offsets are FIXED per panel (organized randomness, stable
// across loads); each panel carries its own accent edge light, as if lit
// from off-screen. Content and proof lines unchanged.
const branches = [
  {
    name: 'Unity & Engine',
    pose: '--ry:-7deg; --rz:0.8deg; --dy:-16px; --ry-m:-2deg; --dx:-10px; --side:-1',
    accent: 'var(--trail-amber)',
    nodes: [
      { label: 'GameObject architecture' },
      { label: 'DOTS / ECS' },
      { label: 'Jobs + Burst' },
      { label: 'Addressables', proof: 'Cargo Simulator chunk streaming' },
      { label: 'Profiling' },
    ],
  },
  {
    name: 'Architecture',
    pose: '--ry:5deg; --rz:-0.6deg; --dy:28px; --ry-m:2deg; --dx:10px; --side:1',
    accent: 'var(--neon-violet)',
    nodes: [
      { label: 'Composition over inheritance' },
      { label: 'DI — Zenject / VContainer' },
      { label: 'SOLID' },
      { label: 'Modular assemblies', proof: 'HG framework, 10+ titles' },
    ],
  },
  {
    name: 'Multiplayer',
    pose: '--ry:-4deg; --rz:0.4deg; --dy:-36px; --ry-m:-2deg; --dx:-8px; --side:-1',
    accent: 'var(--neon-cyan)',
    nodes: [
      { label: 'Client-server model' },
      { label: 'Replication', proof: 'Highstreet VR multiplayer' },
      { label: 'Prediction' },
      { label: 'Packing & compression' },
    ],
  },
  {
    name: 'VR & Physics',
    pose: '--ry:7deg; --rz:-1deg; --dy:20px; --ry-m:2deg; --dx:12px; --side:1',
    accent: 'var(--ink)',
    nodes: [
      { label: 'IK' },
      { label: 'Joints & constraints', proof: 'Highstreet VR combat' },
      { label: 'Interaction systems' },
    ],
  },
  {
    name: 'AI & Procedural',
    pose: '--ry:-6deg; --rz:0.7deg; --dy:40px; --ry-m:-2deg; --dx:-12px; --side:-1',
    accent: 'var(--trail-amber)',
    nodes: [
      { label: 'FSM', proof: 'Cargo Simulator delivery agents' },
      { label: 'Behavior trees' },
      { label: 'NavMesh' },
      { label: 'Procedural roads', proof: 'Cargo Simulator' },
    ],
  },
  {
    name: 'Backend & Tools',
    pose: '--ry:4deg; --rz:-0.5deg; --dy:-24px; --ry-m:2deg; --dx:8px; --side:1',
    accent: 'var(--neon-violet)',
    nodes: [
      { label: 'ASP.NET' },
      { label: 'MySQL / NoSQL' },
      { label: 'Firebase' },
      { label: 'CI/CD', proof: 'HG Builder — 2+ hrs/day saved' },
      { label: 'Python' },
    ],
  },
];
---

<section class="section" id="skills">
  <div class="container reveal">
    <h2 class="section-title"><span class="index">02 /</span> Systems map</h2>
    <p class="lede">
      No levels, no percentages. Where it matters, a node points at the shipped work that
      proves it.
    </p>
    <div class="stage">
      {
        branches.map((branch) => (
          <article class="panel" style={`${branch.pose}; --accent:${branch.accent}`}>
            <h3>{branch.name}</h3>
            <ul>
              {branch.nodes.map((node) => (
                <li>
                  <span class="node">{node.label}</span>
                  {node.proof && <span class="proof">used in: {node.proof}</span>}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .lede {
    margin-bottom: var(--space-5);
  }

  .stage {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
    perspective: 1400px;
  }

  @media (min-width: 768px) {
    .stage {
      gap: var(--space-4) var(--space-3);
      grid-template-columns: 1fr 1fr 1fr;
      padding-block: var(--space-5);
    }
  }

  .panel {
    background: var(--surface);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    border-radius: 0;
    /* lit from off-screen: faint one-sided outer glow in the accent */
    box-shadow: calc(var(--side) * 14px) 0 32px -18px var(--accent);
    padding: var(--space-4);
    transition:
      transform 0.3s ease-out,
      border-color 0.3s ease-out,
      box-shadow 0.3s ease-out;
  }

  @media (min-width: 768px) {
    .panel {
      transform: translateY(var(--dy)) rotateY(var(--ry)) rotateZ(var(--rz));
    }

    .panel:hover,
    .panel:focus-within {
      border-color: color-mix(in srgb, var(--accent) 85%, transparent);
      box-shadow: calc(var(--side) * 18px) 0 38px -16px var(--accent);
      transform: translateY(calc(var(--dy) - 6px)) rotateY(0deg) rotateZ(0deg);
    }
  }

  /* Mobile: stacked, tilts reduced to ±2°, small alternating x-offsets */
  @media (max-width: 767px) {
    .panel {
      transform: translateX(var(--dx)) rotateY(var(--ry-m));
    }
  }

  h3 {
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: flex;
    flex-direction: column;
  }

  .node {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .node::before {
    color: var(--accent);
    content: '▪ ';
  }

  .proof {
    color: var(--ink-dim);
    font-size: var(--text-xs);
    padding-left: var(--space-3);
  }
</style>
