---

<section class="section" id="timeline">
  <div class="container reveal">
    <h2 class="section-title"><span class="index">03 /</span> Quest log</h2>
    <p class="lede">Experience, newest first.</p>
    <div class="log-wrap">
      <span class="route-line" aria-hidden="true"></span>
      <ol>
      {
        entries.map((entry) => (
          <li>
            <p class="stamp">
              <span class="check" aria-hidden="true">✓</span>
              <span class="period">[{entry.period}]</span>
            </p>
            <h3>{entry.title}</h3>
            <ul class="bullets">
              {entry.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
            {entry.chips.length > 0 && (
              <ul class="chip-row">
                {entry.chips.map((c) => (
                  <li class="chip">{c}</li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
      </ol>
    </div>
  </div>
</section>

<style>
  .log-wrap {
    position: relative;
  }

  /* Glowing route line — draws in when the section reveals */
  .route-line {
    background: rgba(139, 92, 246, 0.45);
    border-radius: var(--radius);
    bottom: 0;
    left: 0;
    position: absolute;
    top: 4px;
    transform-origin: top;
    width: 2px;
  }

  :global(html.js) .reveal .route-line {
    transform: scaleY(0);
    transition: transform 1.1s ease-out 0.15s;
  }

  :global(html.js) .reveal.in .route-line {
    transform: scaleY(1);
  }

  ol {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0 0 0 var(--space-5);
  }

  /* No boxes: text sits directly on the page; the route line and nodes
     plus typography carry the structure. */
  ol > li {
    position: relative;
  }

  /* waypoint node — small sharp square on the route */
  ol > li::before {
    background: var(--void);
    border: 1px solid rgba(139, 92, 246, 0.7);
    content: '';
    height: 8px;
    left: calc(-1 * var(--space-5) - 3.5px);
    position: absolute;
    top: 7px;
    width: 8px;
  }

  .stamp {
    display: flex;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    margin-bottom: var(--space-1);
  }

  .check {
    color: var(--neon-cyan);
  }

  .period {
    color: var(--ink-dim);
  }

  h3 {
    font-size: var(--text-md);
    margin-bottom: var(--space-2);
  }

  .bullets {
    color: var(--ink-dim);
    font-size: var(--text-sm);
    margin: 0 0 var(--space-2);
    padding-left: 1.2em;
  }

  .bullets li + li {
    margin-top: var(--space-1);
  }
</style>
