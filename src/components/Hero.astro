---
import { SITE } from '../data/site';

const chips = [
  'Shipped on Steam',
  '400K+ players served',
  'VR multiplayer',
  '10+ yrs building games',
];
---

<section class="hero">
  <div class="container">
    <p class="role">{SITE.role}</p>
    <h1 id="hero-name">Enes Sahin</h1>
    <p class="tagline">I build game systems that ship and scale.</p>
    <ul class="chip-row" aria-label="Highlights">
      {chips.map((chip) => <li class="chip">{chip}</li>)}
    </ul>
    <div class="ctas">
      <a class="btn btn-primary" href={SITE.cvPath} download>Download CV</a>
      <a class="btn btn-secondary" href="#projects">View projects</a>
      <a class="icon-link" href={`mailto:${SITE.email}`} aria-label="Email Enes Sahin">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m2 7 10 6 10-6" />
        </svg>
      </a>
      <a class="icon-link" href={SITE.github} target="_blank" rel="noopener" aria-label="GitHub profile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03a9.56 9.56 0 0 1 5 0c1.91-1.3 2.75-1.03 2.75-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85V21c0 .27.18.58.69.48A10 10 0 0 0 22 12 10 10 0 0 0 12 2z" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Headlight sweep: every 6–9s a warm band of light passes over the name
  // once. The element never moves — only its clipped background animates.
  const name = document.getElementById('hero-name');
  if (name && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let timer = 0;
    const schedule = () => {
      clearTimeout(timer);
      timer = window.setTimeout(fire, 6000 + Math.random() * 3000);
    };
    const done = () => {
      name.classList.remove('sweep');
      schedule();
    };
    const fire = () => {
      name.classList.add('sweep');
      // safety: if animationend never arrives (hidden tab), recover
      clearTimeout(timer);
      timer = window.setTimeout(done, 2500);
    };
    name.addEventListener('animationend', done);
    schedule();
  }
</script>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: calc(100svh - 6rem);
    padding-block: var(--space-6);
    position: relative;
  }

  /* Load moment: content rises as the scene fades up underneath.
     The name itself stays put — its only effect is the light sweep. */
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
  }

  .role,
  .tagline,
  .chip-row,
  .ctas {
    animation: rise 0.3s ease-out backwards;
  }

  .tagline {
    animation-delay: 0.1s;
  }

  .chip-row {
    animation-delay: 0.18s;
  }

  .ctas {
    animation-delay: 0.26s;
  }

  .role {
    color: var(--trail-amber);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
    text-transform: uppercase;
  }

  /* Solid white, fully stable. The sweep is light passing OVER the
     letters: an amber-tinted band in a text-clipped gradient whose base
     matches --ink exactly, so engaging it is seamless. */
  h1 {
    color: var(--ink);
    font-size: clamp(var(--text-2xl), 8vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  h1.sweep {
    background: linear-gradient(
        105deg,
        var(--ink) 0%,
        var(--ink) 38%,
        color-mix(in srgb, var(--trail-amber) 45%, var(--ink)) 50%,
        var(--ink) 62%,
        var(--ink) 100%
      )
      100% 0 / 250% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    animation: headlight 1.2s cubic-bezier(0.45, 0, 0.3, 1) 1;
  }

  @keyframes headlight {
    from {
      background-position: 100% 0;
    }
    to {
      background-position: 0% 0;
    }
  }

  .tagline {
    color: var(--ink);
    font-size: var(--text-md);
    margin-bottom: var(--space-4);
  }

  .chip-row {
    margin-bottom: var(--space-4);
  }

  .ctas {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .icon-link {
    align-items: center;
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      var(--grad-edge) border-box;
    border: 1px solid transparent;
    border-radius: var(--radius);
    color: var(--ink-dim);
    display: inline-flex;
    height: 2.4rem;
    justify-content: center;
    text-decoration: none;
    transition: color 0.2s ease-out;
    width: 2.4rem;
  }

  .icon-link:hover {
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      var(--grad-edge-lit) border-box;
    color: var(--ink);
  }
</style>
