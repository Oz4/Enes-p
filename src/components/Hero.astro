---
import { SITE } from '../data/site';

const chips = [
  'Shipped on Steam',
  '400K+ players served',
  'VR multiplayer',
  '10+ yrs building games',
];
---

<section class="hero">
  <div class="container">
    <p class="role">{SITE.role}</p>
    <h1 class="name">
      <span class="sr-only">Enes Sahin</span>
      <svg class="neon" id="neon-name" viewBox="0 0 640 104" aria-hidden="true">
        <text class="glow" x="2" y="82">{'Enes Sahin'}</text>
        <text class="base" x="2" y="82"><tspan>E</tspan><tspan>n</tspan><tspan>e</tspan><tspan>s</tspan><tspan>{' '}</tspan><tspan>S</tspan><tspan>a</tspan><tspan>h</tspan><tspan>i</tspan><tspan>n</tspan></text>
        <text class="spark" x="2" y="82">{'Enes Sahin'}</text>
      </svg>
    </h1>
    <p class="tagline">I build game systems that ship and scale.</p>
    <ul class="chip-row" aria-label="Highlights">
      {chips.map((chip) => <li class="chip">{chip}</li>)}
    </ul>
    <div class="ctas">
      <a class="btn btn-primary" href={SITE.cvPath} download>Download CV</a>
      <a class="btn btn-secondary" href="#projects">View projects</a>
      <a class="icon-link" href={`mailto:${SITE.email}`} aria-label="Email Enes Sahin">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m2 7 10 6 10-6" />
        </svg>
      </a>
      <a class="icon-link" href={SITE.github} target="_blank" rel="noopener" aria-label="GitHub profile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03a9.56 9.56 0 0 1 5 0c1.91-1.3 2.75-1.03 2.75-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85V21c0 .27.18.58.69.48A10 10 0 0 0 22 12 10 10 0 0 0 12 2z" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Neon-sign glitch accent: every 10–15s ONE random letter dips to 40%
  // for ~120ms — never during the spark trip. Everything else (power-on,
  // breathing glow, spark) is pure CSS. Opacity-only, no layout work.
  const SPARK_PERIOD = 6000; // must match the neon-spark animation
  const SPARK_WINDOW = 1400; // spark trip + safety margin

  if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
    console.info('[hero] neon flicker/spark disabled: prefers-reduced-motion is active');
  } else {
    const letters = [...document.querySelectorAll<SVGTSpanElement>('#neon-name .base tspan')].filter(
      (t) => (t.textContent ?? '').trim().length > 0,
    );
    const t0 = performance.now(); // CSS animations start ≈ now
    const glitch = () => {
      const phase = (performance.now() - t0) % SPARK_PERIOD;
      if (phase > SPARK_WINDOW && letters.length) {
        const letter = letters[Math.floor(Math.random() * letters.length)];
        if (letter) {
          letter.style.opacity = '0.4';
          setTimeout(() => {
            letter.style.opacity = '';
          }, 120);
        }
      }
      setTimeout(glitch, 10000 + Math.random() * 5000);
    };
    setTimeout(glitch, 10000 + Math.random() * 5000);
  }
</script>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: calc(100svh - 6rem);
    padding-block: var(--space-6);
    position: relative;
  }

  /* Load moment: content rises as the scene fades up underneath.
     The name itself stays put — its only effect is the light sweep. */
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
  }

  .role,
  .tagline,
  .chip-row,
  .ctas {
    animation: rise 0.3s ease-out backwards;
  }

  .tagline {
    animation-delay: 0.1s;
  }

  .chip-row {
    animation-delay: 0.18s;
  }

  .ctas {
    animation-delay: 0.26s;
  }

  .role {
    color: var(--trail-amber);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
    text-transform: uppercase;
  }

  /* --- Neon sign: three SVG text layers. Letters never move, never
     change hue — all motion is light (opacity/filter only). --- */
  .name {
    margin-bottom: var(--space-3);
  }

  .sr-only {
    clip: rect(0 0 0 0);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .neon {
    display: block;
    height: auto;
    overflow: visible;
    width: min(100%, 35rem);
    /* power-on: 2-3 irregular stutters within 0.9s, once per visit.
       Under reduced motion this collapses to its final steady frame. */
    animation: neon-power 0.9s linear 1 backwards;
  }

  .neon text {
    font-family: var(--font-display);
    font-size: 84px;
    font-stretch: expanded;
    font-weight: 900;
    letter-spacing: -0.01em;
  }

  .neon .base {
    fill: rgba(255, 255, 255, 0.92);
  }

  /* tube glow: blurred warm copy breathing ±6% */
  .neon .glow {
    fill: color-mix(in srgb, var(--trail-amber) 55%, rgba(255, 255, 255, 0.92));
    filter: blur(14px);
    animation: neon-breathe 4s ease-in-out infinite;
  }

  /* outline spark: a short bright dash travels the letter paths once per
     6s cycle (~1s per trip), invisible while parked */
  .neon .spark {
    fill: none;
    stroke: color-mix(in srgb, var(--trail-amber) 65%, rgba(255, 255, 255, 1));
    stroke-dasharray: 60 560;
    stroke-width: 2.4;
    opacity: 0;
    animation: neon-spark 6s linear infinite;
  }

  @keyframes neon-power {
    0% { opacity: 0; }
    8% { opacity: 0; }
    8.1% { opacity: 1; }
    16% { opacity: 1; }
    16.1% { opacity: 0.2; }
    24% { opacity: 0.2; }
    24.1% { opacity: 1; }
    34% { opacity: 1; }
    34.1% { opacity: 0.45; }
    42% { opacity: 0.45; }
    42.1% { opacity: 1; }
    100% { opacity: 1; }
  }

  @keyframes neon-breathe {
    0% { opacity: 0.72; }
    50% { opacity: 0.81; }
    100% { opacity: 0.72; }
  }

  @keyframes neon-spark {
    0% { stroke-dashoffset: 0; opacity: 1; }
    16.6% { stroke-dashoffset: -620; opacity: 1; }
    16.7% { stroke-dashoffset: -620; opacity: 0; }
    100% { stroke-dashoffset: -620; opacity: 0; }
  }

  .tagline {
    color: var(--ink);
    font-size: var(--text-md);
    margin-bottom: var(--space-4);
  }

  .chip-row {
    margin-bottom: var(--space-4);
  }

  .ctas {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .icon-link {
    align-items: center;
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      var(--grad-edge) border-box;
    border: 1px solid transparent;
    border-radius: var(--radius);
    color: var(--ink-dim);
    display: inline-flex;
    height: 2.4rem;
    justify-content: center;
    text-decoration: none;
    transition: color 0.2s ease-out;
    width: 2.4rem;
  }

  .icon-link:hover {
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      var(--grad-edge-lit) border-box;
    color: var(--ink);
  }
</style>
