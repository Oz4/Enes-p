---
import { SITE } from '../data/site';

const chips = [
  'Shipped on Steam',
  '400K+ players served',
  'VR multiplayer',
  '10+ yrs building games',
];
---

<section class="hero">
  <div class="container">
    <p class="role">{SITE.role}</p>
    <h1>{SITE.name}</h1>
    <p class="positioning">{SITE.positioning}</p>
    <ul class="chip-row" aria-label="Highlights">
      {chips.map((chip) => <li class="chip">{chip}</li>)}
    </ul>
    <div class="ctas">
      <a class="btn btn-primary" href={SITE.cvPath} download>Download CV</a>
      <a class="btn btn-secondary" href="#projects">View projects</a>
      <a class="icon-link" href={`mailto:${SITE.email}`} aria-label="Email Enes Sahin">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m2 7 10 6 10-6" />
        </svg>
      </a>
      <a class="icon-link" href={SITE.github} target="_blank" rel="noopener" aria-label="GitHub profile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03a9.56 9.56 0 0 1 5 0c1.91-1.3 2.75-1.03 2.75-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85V21c0 .27.18.58.69.48A10 10 0 0 0 22 12 10 10 0 0 0 12 2z" />
        </svg>
      </a>
    </div>
    <a class="scroll-cue" href="#projects">↓ scroll</a>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: calc(100svh - 6rem);
    padding-block: var(--space-6);
    position: relative;
  }

  /* Static world-grid background — the sim replaces this in Phase 2 */
  .hero::before {
    animation: grid-in 0.9s ease-out;
    background-image:
      linear-gradient(var(--chunk-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--chunk-line) 1px, transparent 1px);
    background-size: 48px 48px;
    content: '';
    inset: 0;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 30%, transparent 75%);
    opacity: 0.35;
    position: absolute;
    transition: opacity 0.8s;
  }

  /* Once the canvas sim owns the background, retire the static grid. */
  :global(html.sim-on) .hero::before {
    opacity: 0;
  }

  @keyframes grid-in {
    from {
      opacity: 0;
    }
  }

  /* Page-load moment: one orchestrated stagger, ≤ 1.2s total.
     prefers-reduced-motion collapses all of it via global.css. */
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
  }

  .role,
  h1,
  .positioning,
  .chip-row,
  .ctas,
  .scroll-cue {
    animation: rise 0.3s ease-out backwards;
  }

  h1 {
    animation-delay: 0.05s;
  }

  .positioning {
    animation-delay: 0.1s;
  }

  .chip-row {
    animation-delay: 0.18s;
  }

  .ctas {
    animation-delay: 0.26s;
  }

  .scroll-cue {
    animation-delay: 0.4s;
  }

  .container {
    position: relative;
  }

  .role {
    color: var(--signal);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(var(--text-2xl), 8vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  .positioning {
    color: var(--ink);
    font-size: var(--text-sm);
    line-height: 1.5;
    max-width: 38rem;
    margin-bottom: var(--space-4);
  }

  @media (min-width: 768px) {
    .positioning {
      font-size: var(--text-md);
    }
  }

  .chip-row {
    margin-bottom: var(--space-4);
  }

  .ctas {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .icon-link {
    align-items: center;
    border: 1px solid var(--chunk-line);
    border-radius: 4px;
    color: var(--ink-dim);
    display: inline-flex;
    justify-content: center;
    height: 2.4rem;
    width: 2.4rem;
  }

  .icon-link:hover {
    border-color: var(--signal);
    color: var(--ink);
  }

  .scroll-cue {
    bottom: calc(-1 * var(--space-5));
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    position: absolute;
    text-decoration: none;
  }
</style>
