---
// Sandbox controls (PLAN.md v1.1). The panel and the nav toggle only appear
// once the sim is running — with JS off (or reduced motion) neither exists,
// and the CV is completely unaffected.
---

<div class="sandbox-panel" id="sandbox-panel" role="region" aria-label="Sandbox controls" hidden>
  <p class="title">sandbox</p>
  <div class="tools" role="group" aria-label="Tool">
    <button data-tool="road" aria-pressed="true">road</button>
    <button data-tool="depot" aria-pressed="false">depot</button>
    <button data-tool="agent" aria-pressed="false">agent</button>
  </div>
  <p class="hint" id="sandbox-hint">click near a chunk edge to toggle a road</p>
  <p class="fsm-title">agents <span class="fsm-legend">idle → pickup → deliver</span></p>
  <ul class="fsm" id="sandbox-agents"></ul>
  <button class="exit btn btn-primary" id="sandbox-exit">Exit sandbox</button>
</div>

<script>
  import { onSimReady, type SimHandle } from '../sim/engine';

  const HINTS: Record<string, string> = {
    road: 'click near a chunk edge to toggle a road',
    depot: 'click a chunk to place or remove a depot',
    agent: 'click to dispatch an agent from the nearest depot',
  };

  onSimReady((sim: SimHandle) => {
    const panel = document.getElementById('sandbox-panel');
    const toggle = document.getElementById('sandbox-toggle-btn');
    const exit = document.getElementById('sandbox-exit');
    const hint = document.getElementById('sandbox-hint');
    const list = document.getElementById('sandbox-agents');
    const canvas = document.getElementById('sim-canvas');
    const tools = panel?.querySelectorAll<HTMLButtonElement>('[data-tool]');
    if (!panel || !toggle || !exit || !hint || !list || !tools) return;

    let timer = 0;

    function renderAgents(): void {
      const states = sim.agentStates();
      const rows = states.slice(0, 8);
      list!.innerHTML =
        rows.map((s, i) => `<li><span>#${String(i + 1).padStart(2, '0')}</span><b data-s="${s}">${s}</b></li>`).join('') +
        (states.length > 8 ? `<li class="more">+${states.length - 8} more</li>` : '');
    }

    function enter(): void {
      sim.enterSandbox();
      panel!.hidden = false;
      toggle!.textContent = 'Exit sandbox';
      timer = window.setInterval(renderAgents, 300);
      renderAgents();
      exit!.focus();
    }

    function leave(): void {
      sim.exitSandbox();
      panel!.hidden = true;
      toggle!.textContent = 'Sandbox';
      clearInterval(timer);
      toggle!.focus();
    }

    toggle.hidden = false;
    toggle.addEventListener('click', () => (sim.inSandbox() ? leave() : enter()));
    exit.addEventListener('click', leave);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && sim.inSandbox()) leave();
    });

    for (const btn of tools) {
      btn.addEventListener('click', () => {
        const t = btn.dataset.tool as 'road' | 'depot' | 'agent';
        sim.setTool(t);
        hint!.textContent = HINTS[t] ?? '';
        for (const b of tools) b.setAttribute('aria-pressed', String(b === btn));
      });
    }

    canvas?.addEventListener('sim-feedback', (e) => {
      hint!.textContent = (e as CustomEvent<string>).detail;
    });
  });
</script>

<style>
  /* scoped display:flex would defeat the hidden attribute without this */
  .sandbox-panel[hidden] {
    display: none;
  }

  .sandbox-panel {
    background: var(--panel);
    border: 1px solid var(--chunk-line);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: calc(100vw - 2 * var(--space-3));
    padding: var(--space-3);
    position: fixed;
    right: var(--space-3);
    top: 4.5rem;
    width: 15rem;
    z-index: 30;
  }

  .title {
    color: var(--signal);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  .tools {
    display: flex;
    gap: var(--space-2);
  }

  .tools button {
    background: none;
    border: 1px solid var(--chunk-line);
    border-radius: 3px;
    color: var(--ink-dim);
    cursor: pointer;
    flex: 1;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: var(--space-1) 0;
  }

  .tools button[aria-pressed='true'] {
    border-color: var(--signal);
    color: var(--signal);
  }

  .hint {
    color: var(--ink-dim);
    font-size: var(--text-xs);
    margin: 0;
    min-height: 2.2em;
  }

  .fsm-title {
    border-top: 1px solid var(--chunk-line);
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    margin: 0;
    padding-top: var(--space-2);
  }

  .fsm-legend {
    color: var(--chunk-line);
    float: right;
  }

  .fsm {
    display: flex;
    flex-direction: column;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    gap: 2px;
    list-style: none;
    margin: 0;
    max-height: 10rem;
    overflow-y: auto;
    padding: 0;
  }

  .fsm :global(li) {
    color: var(--ink-dim);
    display: flex;
    justify-content: space-between;
  }

  .fsm :global(b) {
    font-weight: 400;
  }

  .fsm :global(b[data-s='idle']) {
    color: var(--ink-dim);
  }

  .fsm :global(b[data-s='pickup']),
  .fsm :global(b[data-s='deliver']) {
    color: var(--telemetry);
  }

  .fsm :global(.more) {
    color: var(--chunk-line);
  }

  .exit {
    margin-top: var(--space-1);
    text-align: center;
  }
</style>
