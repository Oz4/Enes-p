---
// Placeholder showreel: a recorded loop of this site's own simulation until
// Enes captures real footage (PLAN.md §7, item 1). Real file replaces
// public/media/showreel.webm + showreel-poster.svg.
---

<section class="section">
  <div class="container reveal">
    <video
      id="showreel"
      poster="/media/showreel-poster.svg"
      preload="none"
      muted
      loop
      playsinline
      controls
      width="1280"
      height="720"
    >
      <source src="/media/showreel.webm" type="video/webm" />
    </video>
    <p class="caption">
      showreel placeholder — real capture pending: IK hand placement · open-world streaming ·
      VR grabbing &amp; combat · agents pathfinding · editor tooling
    </p>
  </div>
</section>

<script>
  // Muted autoplay on hover (PLAN.md §3.2); controls remain for keyboard/touch.
  const video = document.getElementById('showreel') as HTMLVideoElement | null;
  if (video && matchMedia('(hover: hover)').matches) {
    video.addEventListener('mouseenter', () => {
      video.play().catch(() => {});
    });
    video.addEventListener('mouseleave', () => video.pause());
  }
</script>

<style>
  video {
    aspect-ratio: 16 / 9;
    background: var(--asphalt);
    border: 1px solid var(--chunk-line);
    border-radius: 6px;
    display: block;
    height: auto;
    width: 100%;
  }

  .caption {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    margin: var(--space-2) 0 0;
  }
</style>
