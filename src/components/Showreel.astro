    background:
      repeating-linear-gradient(
        -45deg,
        transparent 0 14px,
        var(--panel) 14px 16px
      ),
      var(--asphalt);
    border: 1px solid var(--chunk-line);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    justify-content: center;
    padding: var(--space-5) var(--space-4);
    text-align: center;
  }

  .label {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    margin: 0;
  }

  .shots {
    color: var(--ink-dim);
    font-size: var(--text-xs);
    margin: 0;
    max-width: 34rem;
  }
