---
// Bottom-sheet case studies. The four articles render once below (real DOM,
// fully readable with JS disabled); with JS on they're hidden from flow and
// cloned into the dialog. Deep-linkable via #/project/<slug>.
import { getCollection, render } from 'astro:content';
import TechBox from './TechBox.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  projects.map(async (p) => ({ p, Content: (await render(p)).Content })),
);
const thumb = (id: string | undefined) =>
  id ? `https://i.ytimg.com/vi/${id}/maxresdefault.jpg` : null;
---

<div class="backdrop" id="sheet-backdrop" hidden></div>
<section class="sheet" id="project-sheet" role="dialog" aria-modal="true" aria-label="Case study" hidden>
  <div class="grab" id="sheet-grab">
    <span class="grab-bar" aria-hidden="true"></span>
    <button class="close" id="sheet-close" aria-label="Close case study">✕</button>
  </div>
  <div class="sheet-scroll" id="sheet-scroll" tabindex="-1"></div>
</section>

<div class="case-articles" id="case-articles">
  <div class="container">
    {
      rendered.map(({ p, Content }) => (
        <article class="case glass" id={`case-${p.id}`} data-slug={p.id}>
          <header>
            <h3 class="case-title">{p.data.title}</h3>
            <p class="case-meta">
              {p.data.studio} · {p.data.period} · {p.data.roleLine}
            </p>
          </header>
          <div class="media-strip" aria-hidden="true">
            {thumb(p.data.trailer) && (
              <img src={thumb(p.data.trailer)} alt="" width="480" height="270" loading="lazy" />
            )}
            {p.data.art && <img src={p.data.art} alt="" width="480" height="228" loading="lazy" />}
          </div>
          <p class="placeholder-note">media: AAA-trailer placeholder — real capture pending</p>
          <div class="prose">
            <Content />
          </div>
          <TechBox tech={p.data.tech} />
          {p.data.trailer && (
            <a
              class="btn btn-secondary link-out"
              href={`https://www.youtube.com/watch?v=${p.data.trailer}`}
              target="_blank"
              rel="noopener"
            >
              Watch trailer (placeholder link)
            </a>
          )}
        </article>
      ))
    }
  </div>
</div>

<script>
  const sheet = document.getElementById('project-sheet') as HTMLElement;
  const backdrop = document.getElementById('sheet-backdrop') as HTMLElement;
  const scroller = document.getElementById('sheet-scroll') as HTMLElement;
  const closeBtn = document.getElementById('sheet-close') as HTMLButtonElement;
  const grab = document.getElementById('sheet-grab') as HTMLElement;

  let openSlug: string | null = null;
  let opener: HTMLElement | null = null;

  const hashFor = (slug: string) => `#/project/${slug}`;
  const slugFromHash = () => {
    const m = location.hash.match(/^#\/project\/([\w-]+)$/);
    return m ? (m[1] as string) : null;
  };

  function show(slug: string): boolean {
    const source = document.getElementById(`case-${slug}`);
    if (!source || !sheet || !backdrop) return false;
    const clone = source.cloneNode(true) as HTMLElement;
    clone.removeAttribute('id');
    for (const el of clone.querySelectorAll('[id]')) el.removeAttribute('id');
    scroller.replaceChildren(clone);
    scroller.scrollTop = 0;
    sheet.setAttribute(
      'aria-label',
      clone.querySelector('.case-title')?.textContent?.trim() || 'Case study',
    );
    sheet.hidden = false;
    backdrop.hidden = false;
    requestAnimationFrame(() => {
      sheet.classList.add('open');
      backdrop.classList.add('open');
    });
    document.documentElement.classList.add('sheet-open');
    openSlug = slug;
    opener = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    closeBtn.focus();
    return true;
  }

  function finalizeClose(): void {
    if (!openSlug) return;
    openSlug = null;
    sheet.classList.remove('open');
    backdrop.classList.remove('open');
    document.documentElement.classList.remove('sheet-open');
    sheet.style.transform = '';
    window.setTimeout(() => {
      if (!openSlug) {
        sheet.hidden = true;
        backdrop.hidden = true;
        scroller.replaceChildren();
      }
    }, 350);
    opener?.focus();
    opener = null;
  }

  /** Close via UI — routes through history so back/forward stay coherent. */
  function requestClose(): void {
    if (slugFromHash()) history.back();
    else finalizeClose();
  }

  window.addEventListener('popstate', () => {
    const slug = slugFromHash();
    if (slug && slug !== openSlug) show(slug);
    else if (!slug && openSlug) finalizeClose();
  });

  // open from rail cards
  document.addEventListener('click', (e) => {
    const card = e.target instanceof Element ? e.target.closest<HTMLElement>('.rail-card') : null;
    if (!card?.dataset.slug) return;
    const slug = card.dataset.slug;
    if (show(slug) && location.hash !== hashFor(slug)) {
      history.pushState(null, '', hashFor(slug));
    }
  });

  closeBtn?.addEventListener('click', requestClose);
  backdrop?.addEventListener('click', requestClose);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && openSlug) requestClose();
  });

  // focus trap
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !openSlug) return;
    const focusables = [
      ...sheet.querySelectorAll<HTMLElement>('button, a[href], [tabindex]:not([tabindex="-1"])'),
    ].filter((el) => el.offsetParent !== null);
    if (!focusables.length) return;
    const first = focusables[0] as HTMLElement;
    const last = focusables[focusables.length - 1] as HTMLElement;
    const active = document.activeElement;
    if (e.shiftKey && (active === first || !sheet.contains(active))) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && (active === last || !sheet.contains(active))) {
      e.preventDefault();
      first.focus();
    }
  });

  // swipe-down on the grab handle
  let dragY = 0;
  let startY = 0;
  grab?.addEventListener('pointerdown', (e) => {
    if (e.target instanceof Element && e.target.closest('button')) return;
    startY = e.clientY;
    dragY = 0;
    grab.setPointerCapture(e.pointerId);
    sheet.style.transition = 'none';
    const move = (ev: PointerEvent) => {
      dragY = Math.max(0, ev.clientY - startY);
      sheet.style.transform = `translateY(${dragY}px)`;
    };
    const up = () => {
      grab.removeEventListener('pointermove', move);
      grab.removeEventListener('pointerup', up);
      sheet.style.transition = '';
      if (dragY > 120) requestClose();
      else sheet.style.transform = '';
    };
    grab.addEventListener('pointermove', move);
    grab.addEventListener('pointerup', up);
  });

  // deep link on load
  const initial = slugFromHash();
  if (initial) show(initial);
</script>

<style>
  .backdrop {
    background: rgba(6, 6, 8, 0.65);
    inset: 0;
    opacity: 0;
    position: fixed;
    transition: opacity 0.3s ease-out;
    z-index: 40;
  }

  .backdrop.open {
    opacity: 1;
  }

  .backdrop[hidden] {
    display: none;
  }

  .sheet {
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    background:
      linear-gradient(rgba(14, 14, 20, 0.82), rgba(14, 14, 20, 0.82)) padding-box,
      var(--grad-edge) border-box;
    border: 1px solid transparent;
    border-bottom: none;
    border-radius: var(--radius); /* sharp top edge */
    bottom: 0;
    display: flex;
    flex-direction: column;
    height: 85vh;
    height: 85dvh;
    left: 0;
    position: fixed;
    right: 0;
    transform: translateY(100%);
    transition: transform 0.32s cubic-bezier(0.32, 0.72, 0.25, 1);
    z-index: 50;
  }

  .sheet.open {
    transform: translateY(0);
  }

  .sheet[hidden] {
    display: none;
  }

  .grab {
    align-items: center;
    cursor: grab;
    display: flex;
    flex: 0 0 auto;
    justify-content: center;
    padding: var(--space-2) var(--space-3);
    position: relative;
    touch-action: none;
  }

  .grab-bar {
    background: var(--edge);
    border-radius: var(--radius);
    height: 4px;
    width: 3rem;
  }

  .close {
    background: var(--surface);
    border: 1px solid var(--edge);
    border-radius: var(--radius);
    color: var(--ink-dim);
    cursor: pointer;
    font-size: var(--text-sm);
    height: 2.2rem;
    position: absolute;
    right: var(--space-3);
    top: var(--space-2);
    transition: color 0.15s ease-out, box-shadow 0.15s ease-out;
    width: 2.2rem;
  }

  .close:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: var(--ink);
  }

  .sheet-scroll {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: var(--space-2) var(--space-4) var(--space-6);
  }

  .sheet-scroll > :global(.case) {
    margin: 0 auto;
    max-width: 46rem;
  }

  /* lock page scroll while the sheet is up */
  :global(html.sheet-open) {
    overflow: hidden;
  }

  /* ------- case article styles (used in-flow without JS AND inside the sheet) ------- */

  :global(html.js) .case-articles {
    display: none;
  }

  .case-articles {
    padding-block: var(--space-5);
  }

  .case-articles .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .case,
  .sheet :global(.case) {
    padding: var(--space-4);
  }

  .sheet :global(.case) {
    background: none;
    border: none;
  }

  .case-title,
  .sheet :global(.case-title) {
    font-size: var(--text-lg);
  }

  .case :global(.case-meta),
  .sheet :global(.case-meta) {
    color: var(--trail-amber);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .case :global(.media-strip),
  .sheet :global(.media-strip) {
    display: flex;
    gap: var(--space-3);
    margin-block: var(--space-3);
    overflow-x: auto;
  }

  .case :global(.media-strip img),
  .sheet :global(.media-strip img) {
    border: 1px solid var(--edge);
    border-radius: var(--radius);
    flex: 0 0 auto;
    height: 9.5rem;
    object-fit: cover;
    width: auto;
  }

  .case :global(.placeholder-note),
  .sheet :global(.placeholder-note) {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.7;
  }

  .case :global(.prose h2),
  .sheet :global(.prose h2) {
    font-size: var(--text-md);
    margin-top: var(--space-4);
  }

  .case :global(.prose h3),
  .sheet :global(.prose h3) {
    color: var(--neon-violet);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-stretch: normal;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin-top: var(--space-3);
    text-transform: uppercase;
  }

  .case :global(.prose p),
  .case :global(.prose li),
  .sheet :global(.prose p),
  .sheet :global(.prose li) {
    color: var(--ink-dim);
  }

  .case :global(.prose strong),
  .sheet :global(.prose strong) {
    color: var(--ink);
  }

  .case :global(.tech-box),
  .sheet :global(.tech-box) {
    margin-block: var(--space-4);
  }

  .case :global(.link-out),
  .sheet :global(.link-out) {
    margin-top: var(--space-2);
  }
</style>
