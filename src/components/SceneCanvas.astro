---
// "Night Delivery Network" WebGL scene container. The static gradient poster
// below is the no-JS / reduced-motion / no-WebGL fallback; the three.js scene
// lazy-loads on first interaction and fades in over it. Pure decoration —
// aria-hidden, never gates content.
//
// The scrim sits between the scene and the page: transparent over the hero,
// easing to ~0.8 after one viewport of scroll so the city recedes to a faint
// pulse behind the document, and settling back to ~0.5 behind Contact.
---

<div class="scene" id="scene-root" aria-hidden="true"></div>
<div class="scene-scrim" aria-hidden="true"></div>

<script>
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function webglOK(): boolean {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch {
      return false;
    }
  }

  let started = false;
  const start = async () => {
    if (started) return;
    started = true;
    for (const evt of TRIGGERS) window.removeEventListener(evt, start);
    const root = document.getElementById('scene-root');
    const conn = (navigator as { connection?: { saveData?: boolean } }).connection;
    if (!root || reduced || conn?.saveData || !webglOK()) return;
    const { initScene } = await import('../scene');
    initScene(root);
  };

  // Deliberately NOT on idle: three.js parse + init is the page's one heavy
  // task, so it waits for the first sign of a human (or a late fallback).
  // The document is fully usable before, over the CSS poster.
  const TRIGGERS = ['pointermove', 'pointerdown', 'touchstart', 'keydown', 'scroll'] as const;
  for (const evt of TRIGGERS) window.addEventListener(evt, start, { passive: true });
  setTimeout(start, 6000);

  // --- scroll-linked scrim -------------------------------------------------
  // Drives --scrim-o (read by the scrim layer's CSS) and broadcasts the value
  // so the scene can shed work while it's dimmed. Scroll-linked values are
  // instantaneous — no tween, so reduced-motion needs no special casing and
  // there is nothing to jank.
  const smooth = (t: number) => t * t * (3 - 2 * t);
  const clamp01 = (v: number) => Math.max(0, Math.min(1, v));
  let lastSent = -1;

  function applyScrim(): void {
    const vh = window.innerHeight || 1;
    let v = smooth(clamp01(window.scrollY / vh)) * 0.8;
    // closing beat: the network resurfaces behind the final CTA
    const contact = document.getElementById('contact');
    if (contact && v > 0.5) {
      const r = contact.getBoundingClientRect();
      const visible = clamp01((vh - Math.max(r.top, 0)) / Math.min(vh, r.height || 1));
      v += (0.5 - v) * smooth(visible);
    }
    const rounded = Math.round(v * 200) / 200;
    if (rounded === lastSent) return;
    lastSent = rounded;
    document.documentElement.style.setProperty('--scrim-o', String(rounded));
    window.dispatchEvent(new CustomEvent('scrimchange', { detail: rounded }));
  }

  let scrimPending = false;
  window.addEventListener(
    'scroll',
    () => {
      if (scrimPending) return;
      scrimPending = true;
      requestAnimationFrame(() => {
        scrimPending = false;
        applyScrim();
      });
    },
    { passive: true },
  );
  window.addEventListener('resize', applyScrim, { passive: true });
  applyScrim();
</script>

<style>
  .scene {
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    position: fixed;
    z-index: -1;
    /* static poster: the city glow without the city */
    background:
      radial-gradient(ellipse 55% 40% at 28% 32%, rgba(139, 92, 246, 0.1), transparent 70%),
      radial-gradient(ellipse 50% 38% at 74% 60%, rgba(34, 211, 238, 0.07), transparent 70%),
      radial-gradient(ellipse 40% 30% at 55% 85%, rgba(255, 180, 84, 0.05), transparent 70%),
      var(--void);
  }

  /* Between scene and content: same fixed z-level, later in DOM = on top */
  .scene-scrim {
    background: var(--void);
    inset: 0;
    opacity: var(--scrim-o, 0);
    pointer-events: none;
    position: fixed;
    z-index: -1;
  }

  .scene :global(canvas) {
    display: block;
    height: 100%;
    opacity: 0;
    transition: opacity 1.2s ease-out;
    width: 100%;
  }

  :global(html.scene-on) .scene :global(canvas) {
    opacity: 1;
  }
</style>
