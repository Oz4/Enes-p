---
import { SITE } from '../data/site';
---

<header class="nav">
  <nav class="container" aria-label="Main">
    <a class="brand" href="/">Enes Sahin</a>
    <ul>
      <li><a href="/#projects">Projects</a></li>
      <li><a href="/#skills">Skills</a></li>
      <li><a href="/#timeline">Timeline</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a class="cv" href={SITE.cvPath} download>Download CV</a></li>
    </ul>
  </nav>
</header>

<style>
  .nav {
    background: var(--asphalt);
    border-bottom: 1px solid var(--chunk-line);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  nav {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    justify-content: space-between;
    padding-block: var(--space-2);
  }

  .brand {
    color: var(--ink);
    font-family: var(--font-display);
    font-stretch: expanded;
    font-size: var(--text-sm);
    font-weight: 800;
    text-decoration: none;
  }

  ul {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  ul a {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-decoration: none;
  }

  ul a:hover {
    color: var(--ink);
  }

  .cv {
    border: 1px solid var(--signal);
    border-radius: 3px;
    color: var(--signal);
    padding: 2px var(--space-2);
  }

  .cv:hover {
    background: var(--signal);
    color: var(--asphalt);
  }

  /* On small screens the hero's primary CTA covers CV download;
     keep the sticky bar to two compact rows. */
  @media (max-width: 639px) {
    .cv {
      display: none;
    }
  }
</style>
