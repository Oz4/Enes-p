---
import { SITE } from '../data/site';
---

<header class="nav">
  <nav class="container" aria-label="Main">
    <a class="brand" href="/">Enes Sahin</a>
    <ul>
      <li><a href="/#projects">Projects</a></li>
      <li><a href="/#skills">Skills</a></li>
      <li><a href="/#timeline">Timeline</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a class="cv" href={SITE.cvPath} download>Download CV</a></li>
    </ul>
  </nav>
</header>

<style>
  .nav {
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    background: rgba(6, 6, 8, 0.7);
    border-bottom: 1px solid var(--edge);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  nav {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    justify-content: space-between;
    padding-block: var(--space-2);
  }

  .brand {
    color: var(--ink);
    font-family: var(--font-display);
    font-stretch: expanded;
    font-size: var(--text-sm);
    font-weight: 800;
    text-decoration: none;
  }

  ul {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  ul a {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-decoration: none;
    transition: color 0.15s ease-out, text-shadow 0.15s ease-out;
  }

  ul a:hover {
    color: var(--ink);
    text-shadow: 0 0 12px rgba(139, 92, 246, 0.5);
  }

  .cv {
    border: 1px solid var(--trail-amber);
    border-radius: 999px;
    color: var(--trail-amber);
    padding: 2px var(--space-3);
    transition: box-shadow 0.2s ease-out, background 0.2s ease-out, color 0.2s ease-out;
  }

  .cv:hover {
    background: var(--trail-amber);
    box-shadow: 0 0 20px rgba(255, 180, 84, 0.4);
    color: var(--void);
    text-shadow: none;
  }

  /* On small screens the hero's primary CTA covers CV download */
  @media (max-width: 639px) {
    .cv {
      display: none;
    }
  }
</style>
