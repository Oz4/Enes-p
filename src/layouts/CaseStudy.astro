---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import TechBox from '../components/TechBox.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, studio, period, summary, tech, art } = project.data;
---

<Base title={`${title} — Enes Sahin`} description={summary}>
  <Nav />
  <main id="main">
    <article class="container">
      <header>
        <p class="crumb"><a href="/#projects">← All projects</a></p>
        <h1>{title}</h1>
        <p class="meta">{studio} · {period}</p>
        {art && <img class="key-art" src={art} alt="" width="840" height="400" loading="eager" />}
      </header>
      <div class="body">
        <div class="prose">
          <slot />
        </div>
        <TechBox tech={tech} />
      </div>
    </article>
  </main>
</Base>

<style>
  article {
    padding-block: var(--space-5) var(--space-6);
  }

  .crumb a {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-decoration: none;
  }

  .crumb a:hover {
    color: var(--ink);
  }

  h1 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .meta {
    color: var(--trail-amber);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    margin-bottom: var(--space-4);
  }

  .key-art {
    border: 1px solid var(--edge);
    border-radius: 6px;
    display: block;
    height: auto;
    margin-bottom: var(--space-4);
    width: 100%;
  }

  .body {
    align-items: start;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .body {
      grid-template-columns: 1fr 20rem;
    }
  }

  .prose :global(h2) {
    font-size: var(--text-lg);
    margin-top: var(--space-5);
  }

  .prose :global(h2:first-child) {
    margin-top: 0;
  }

  .prose :global(h3) {
    color: var(--trail-amber);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-stretch: normal;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin-top: var(--space-4);
    text-transform: uppercase;
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(strong) {
    color: var(--ink);
  }

  .prose :global(p),
  .prose :global(li) {
    color: var(--ink-dim);
  }

  .prose :global(li strong),
  .prose :global(p strong) {
    color: var(--ink);
  }
</style>
